#import "@preview/zh-kit:0.1.0": *

#set text(font: ("EB Garamond", "Kaiti TC", "Hiragino Mincho ProN"), size: 12pt)


#set page(
  paper: "a4",
  margin: (
    top: 6em,
    bottom: 4.5em,
    x: 3em
  ),
  number-align: center,
  flipped: true
)

#let kana-font-size = 1.7em
#let caoshu-font = "KouzanBrushFontSousyo"
#let kana-font = "Hiragino Mincho ProN"
#let han-font = "Kaiti TC"
#let latin-font = "EB Garamond"
// #let caoshu-font = "???????"

#let cell(kana) = {
  if kana.ipa != ""{
    text(font: latin-font)[#text(fill: luma(100))[/#kana.ipa/] #h(1fr) #kana.latin]
    v(-0.8em)
    line(length: 100%, stroke: gray)
    v(-0.5em)
    table(
      align: (left + bottom, right),
      columns: (1.5fr, 1fr),
      stroke: 0pt,
      inset: 0pt,
      row-gutter: 0.8em,
      [#text(font: caoshu-font)[#kana.han-hira]#h(0.2em)#kana.han-hira],[#text(size: kana-font-size, weight: "bold", font: kana-font)[#kana.hira]],
      [#h(1.2em) #kana.han-kata],[#text(size: kana-font-size, weight: "bold", font: kana-font)[#kana.kata]],
    )
  }
}

#let cols = 11

#let position(i) = {
  let x = cols - 2 - calc.rem(i,cols - 1)
  let y = calc.floor(i / (cols - 1))
  return 5 * x + y
}

#let cells = range(50).map(i => cell(kana-chart.at(position(i))))

#let vertical-text(string, font) = {
  stack(dir: ttb,
    ..string.clusters().map(x => text(size: 1.2em, font: font)[#x #v(0.3em)])
  )
}

#let title-cell = [
    #vertical-text("日本語五十音図 発音記号・ローマ字・字源付き", kana-font)
  ]

#let foot-cell = [
  #v(1fr) #vertical-text("公元二零二六年四月廿三日逸飛謹製", han-font)
]

#let col-line-stroke(x) = {
  if x == 0 or x == cols {
    return 1pt
  } else {
    return 0.5pt
  }
}

#table(
  columns: (0.5fr,11fr,0.5fr),
  align: (right, center, left),
  stroke: none,
  foot-cell,
  table(
    align: center,
    columns: (1fr,) * cols,
    row-gutter: 2.1em,
    stroke: none,
    table.cell(rowspan: 5)[#cell(kana-chart.at(50))],
    ..range(cols + 1).map(x => table.vline(x: x, stroke: col-line-stroke(x))),
    ..cells
  ),
  title-cell
)